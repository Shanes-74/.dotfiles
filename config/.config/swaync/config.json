{
  "positionX": "right",
  "positionY": "top",

  "layer-shell": true,
  "layer-shell-cover-screen": true,
  "layer": "overlay",
  "control-center-layer": "overlay",

  "cssPriority": "user",

  "fit-to-screen": false,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 200,

  "control-center-width": 550,
  "control-center-height": 960,
  "control-center-margin-top": 28,
  "control-center-margin-bottom": 28,
  "control-center-margin-right": 28,
  "control-center-margin-left": 0,

  "notification-window-width": 500,
  "notification-icon-size": 48,
  "notification-body-image-height": 240,
  "notification-body-image-width": 240,

  "timeout-low": 2,
  "timeout": 4,
  "timeout-critical": 6,

  "hide-on-clear": false,
  "hide-on-action": false,
  "script-fail-notify": true,

  "scripts": {
    "example-script": {
      "exec": "echo 'Do something...'",
      "urgency": "Normal"
    }
  },

  "widgets": [
    "title",
    "dnd",
    "buttons-grid",
    "mpris",
    "notifications"
  ],

  "widget-config": {
    "title": {
      "text": "Notificações",
      "button-text": "Limpar Tudo"
    },
    "dnd": {
      "text": "Não Perturbe"
    },
    "mpris": {
      "image-size": 96,
      "image-radius": 50
    },
    "volume": {
      "label": "",
      "show-per-app": true
    },
    "backlight": {
      "label": "󰃞"
    },
    "buttons-grid": {
      "actions": [
        { "label": "",   "command": "swaync-client -cp && nohup nmgui" },
        { "label": "󰂯", "command": "swaync-client -cp && nohup blueman-manager" },
        { "label": "",   "command": "swaync-client -cp && nohup pavucontrol" },
        { "label": "󰔎", "command": "~/.config/scripts/theme/themetoggle.py" },
        { "label": "󰖔", "command": "night-mode" },
        { "label": "",   "command": "swaync-client -cp && nohup hyprmod" }
      ]
    }
  }
}