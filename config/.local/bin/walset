#!/usr/bin/env bash
set -euo pipefail

# =====================================================
# WALSET — Clean Theme Manager
# =====================================================

HOME_DIR="$HOME"
CACHE_DIR="$HOME_DIR/.cache/walset"
STATE_FILE="$CACHE_DIR/state.json"

WALLPAPER_DIR="$HOME_DIR/Imagens/Wallpapers"
CONFIG_MATUGEN="$HOME_DIR/.config/matugen/config.toml"
ROFI_THEME="$HOME_DIR/.config/rofi/rofi.rasi"

SDDM_ASSETS_DIR="$HOME_DIR/.dotfiles/sddm/sddm-current/assets"
SDDM_BG="$SDDM_ASSETS_DIR/background.jpg"

mkdir -p "$CACHE_DIR"

export PATH="$HOME_DIR/.local/bin:/usr/local/bin:/usr/bin:/bin:$PATH"
export XDG_RUNTIME_DIR="/run/user/$(id -u)"


# ---------- DEP CHECK ----------

for cmd in awww matugen rofi jq; do
    command -v "$cmd" >/dev/null 2>&1 || {
        echo "❌ Dependência faltando: $cmd"
        exit 1
    }
done


# ---------- NOTIFY ----------

NOTIFY_ID=""

notify_start() {
    if command -v notify-send >/dev/null 2>&1; then
        NOTIFY_ID=$(notify-send "Walset" "Aplicando tema…" \
            --icon=preferences-desktop-wallpaper \
            --urgency=normal \
            --print-id 2>/dev/null) || {
            # Fallback para versões sem --print-id
            NOTIFY_ID=9901
            notify-send "Walset" "Aplicando tema…" \
                --icon=preferences-desktop-wallpaper \
                --urgency=low \
                --replace-id="$NOTIFY_ID" 2>/dev/null || true
        }
    fi
}

notify_done() {
    if command -v notify-send >/dev/null 2>&1 && [[ -n "$NOTIFY_ID" ]]; then
        local wallpaper_name
        wallpaper_name=$(basename "$WALLPAPER")
        notify-send "Walset" "Tema aplicado" \
            --icon=dialog-information \
            --urgency=low \
            --replace-id="$NOTIFY_ID" 2>/dev/null || true
    fi
}

notify_error() {
    if command -v notify-send >/dev/null 2>&1 && [[ -n "$NOTIFY_ID" ]]; then
        notify-send "Walset" "$1" \
            --icon=dialog-error \
            --urgency=critical \
            --replace-id="$NOTIFY_ID" 2>/dev/null || true
    fi
}


# ---------- FUNCTIONS ----------

save_state() {
    jq -n \
        --arg wallpaper "$1" \
        --arg scheme "$2" \
        --arg mode "$3" \
        '{wallpaper: $wallpaper, scheme: $scheme, mode: $mode}' \
        > "$STATE_FILE"
}

load_state() {
    if [[ -f "$STATE_FILE" ]]; then
        SCHEME=$(jq -r '.scheme // "content"' "$STATE_FILE")
        MODE=$(jq -r '.mode // "dark"' "$STATE_FILE")
    else
        SCHEME="content"
        MODE="dark"
    fi
}

apply_hooks() {
    #hyprctl reload >/dev/null 2>&1 || true
    pkill -USR1 kitty >/dev/null 2>&1 || true
    swaync-client -rs >/dev/null 2>&1 || true

    killall -q swayosd-server >/dev/null 2>&1 || true
    killall -q xdg-desktop-portal-gtk >/dev/null 2>&1 || true
    killall -q gnome-clocks >/dev/null 2>&1 || true

    pkill -x polkit-gnome-authentication-agent-1 >/dev/null 2>&1 || true
    /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 >/dev/null 2>&1 &

    pkill waybar >/dev/null 2>&1 || true
    sleep 0.5
    waybar >/dev/null 2>&1 &
}

update_sddm() {
    mkdir -p "$SDDM_ASSETS_DIR"
    if cp "$WALLPAPER" "$SDDM_BG"; then
        echo "🖼  SDDM background atualizado"
    else
        echo "⚠️  Falha ao atualizar SDDM background"
    fi
    command -v sddm-sync >/dev/null 2>&1 && sddm-sync || true
}


# ---------- MAIN ----------

load_state
notify_start

# =====================================================
# 1. Escolha do wallpaper
# =====================================================
if [[ -n "${1:-}" ]]; then
    WALLPAPER="$1"
else
    mapfile -t FILES < <(
        find "$WALLPAPER_DIR" -type f \
        \( -iname "*.jpg" -o -iname "*.png" -o -iname "*.jpeg" -o -iname "*.webp" \)
    )

    [[ ${#FILES[@]} -eq 0 ]] && {
        echo "❌ Nenhum wallpaper encontrado"
        notify_error "Nenhum wallpaper encontrado em $WALLPAPER_DIR"
        exit 1
    }

    WALLPAPER="${FILES[RANDOM % ${#FILES[@]}]}"
fi

# =====================================================
# 2. Validações do arquivo de imagem
# =====================================================
if [[ ! -f "$WALLPAPER" ]]; then
    echo "❌ Arquivo não encontrado: $WALLPAPER"
    notify_error "Arquivo não encontrado: $(basename "$WALLPAPER")"
    exit 1
fi

if [[ ! -r "$WALLPAPER" ]]; then
    echo "❌ Sem permissão de leitura: $WALLPAPER"
    notify_error "Sem permissão de leitura: $(basename "$WALLPAPER")"
    exit 1
fi

if command -v magick &>/dev/null; then
    if ! magick identify "$WALLPAPER" &>/dev/null; then
        echo "❌ Arquivo de imagem inválido ou corrompido: $WALLPAPER"
        notify_error "Imagem inválida ou corrompida: $(basename "$WALLPAPER")"
        exit 1
    fi
fi

# =====================================================
# 3. Escolha do esquema de cores
# =====================================================
if [[ -n "${2:-}" ]]; then
    SELECTED="$2"
else
    CHOICE=$(printf "%s\n" \
        "Conteúdo" "Expressivo" "Fidelidade" "Salada de Frutas" \
        "Monocromático" "Neutro" "Arco-Íris" "Ponto Tonal" "Vibrante" \
        | rofi -dmenu -i -p "Esquema de Cores" -theme "$ROFI_THEME")

    declare -A MAP=(
        ["Conteúdo"]="content"
        ["Expressivo"]="expressive"
        ["Fidelidade"]="fidelity"
        ["Salada de Frutas"]="fruit-salad"
        ["Monocromático"]="monochrome"
        ["Neutro"]="neutral"
        ["Arco-Íris"]="rainbow"
        ["Ponto Tonal"]="tonal-spot"
        ["Vibrante"]="vibrant"
    )

    SELECTED="${MAP[$CHOICE]:-$SCHEME}"
fi

# =====================================================
# 4. Modo (claro/escuro)
# =====================================================
MODE="${3:-$MODE}"

# =====================================================
# 5. Aplicar wallpaper com awww (transição aleatória)
# =====================================================
echo "🖼  Aplicando wallpaper: $(basename "$WALLPAPER")"

TRANS=(fade outer center wipe wave grow)
T="${TRANS[RANDOM % ${#TRANS[@]}]}"

RESOLUTION=$(awww query | grep -oP '\d+x\d+' | head -1)
SCREEN_W=$(echo "$RESOLUTION" | cut -dx -f1)
SCREEN_H=$(echo "$RESOLUTION" | cut -dx -f2)

POS_X=$((RANDOM % SCREEN_W))
POS_Y=$((RANDOM % SCREEN_H))

awww img "$WALLPAPER" \
    --transition-type "$T" \
    --transition-duration 1.7 \
    --transition-fps 144 \
    --transition-bezier 0.4,0.0,0.2,1.0 \
    --transition-step 90 \
    --transition-pos "${POS_X},${POS_Y}"

# =====================================================
# 6. Verificar configuração do matugen
# =====================================================
if [[ ! -f "$CONFIG_MATUGEN" ]]; then
    echo "❌ Arquivo de configuração do matugen não encontrado: $CONFIG_MATUGEN"
    notify_error "Configuração do matugen não encontrada"
    exit 1
fi

# =====================================================
# 7. Executar matugen
# =====================================================
echo "🎨 Gerando cores com matugen (esquema: $SELECTED, modo: $MODE)..."

if ! matugen \
    -c "$CONFIG_MATUGEN" \
    image "$WALLPAPER" \
    -m "$MODE" \
    -t "scheme-$SELECTED" \
    --source-color-index 0; then
    echo "❌ Falha na execução do matugen. Abortando."
    notify_error "Falha ao gerar paleta de cores"
    exit 1
fi

# =====================================================
# 8. Salvar estado e aplicar hooks
# =====================================================
echo "💾 Salvando estado..."
save_state "$WALLPAPER" "$SELECTED" "$MODE"

echo "🔄 Aplicando hooks..."
apply_hooks

echo "🖥  Atualizando SDDM..."
update_sddm

notify_done
echo "✅ Tema aplicado com sucesso!"